{
  "listen_addr": "127.0.0.1:4000",
  "upstream_base": "https://api.githubcopilot.com",
  "required_headers": {
    "user-agent": "copilot/1.0.2",
    "copilot-integration-id": "copilot-developer-cli"
  },
  "max_retries": 3,
  "retry_backoff": "1s",
  "rate_limit_seconds": 0,
  "claude_haiku_fallback_models": [
    "gpt-5-mini",
    "grok-code-fast-1"
  ]
}
